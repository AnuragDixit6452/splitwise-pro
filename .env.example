# Postgres connection string
# Local Docker: postgres://dixit_user:secure_ledger_password@localhost:5432/expense_tracker
# Neon: paste the connection string from the Neon dashboard (include ?sslmode=require)
DATABASE_URL=postgres://dixit_user:secure_ledger_password@localhost:5432/expense_tracker

# Fixed unlock PIN for Dixit's vault
APP_PIN=1495

# HMAC secret for session tokens (use a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-string

# Required for Neon / most managed Postgres
DATABASE_SSL=true

# Server port (production / docker). Dev API uses 4000 via npm run dev:server
PORT=4000

# Optional: leave empty when frontend and API share the same origin
# VITE_API_URL=
